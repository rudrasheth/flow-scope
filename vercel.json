{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "memory": 2048,
      "maxDuration": 300,
      "includeFiles": [
        "server/data/supply_chain_data.csv",
        "server/data/companies_with_bom_filters.csv",
        "server/data/merged_harmonized_sections.csv"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
