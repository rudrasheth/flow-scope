{
  "version": 2,
  "installCommand": "cd client && npm install --no-audit --no-fund --legacy-peer-deps",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
