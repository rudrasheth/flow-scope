# ─── Server ───
PORT=3001

# ─── Neo4j Graph Database ───
# Required for graph-based queries. Falls back to CSV-based in-memory graph if unavailable.
# Sign up at https://neo4j.com/cloud/aura-free/ for a free AuraDB instance.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ─── Data Source ───
# Set to "neo4j" to use the graph database, or "csv" for CSV-only mode (no Neo4j required)
DATA_SOURCE=csv

# ─── News API (Optional) ───
# Used for live trade news on the dashboard. Get a free key at https://newsdata.io/
NEWS_API_KEY=your_newsdata_api_key_here

# ─── Gemini AI (Optional) ───
# Used by the trace engine for AI-powered BOM inference. Get a key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
